{
  "name": "news-monitor-pwa",
  "version": "2.3.0",
  "type": "module",
  "description": "Progressive Web App for global news monitoring and social listening",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "analyze": "npx vite-bundle-analyzer dist/assets/index-*.js"
  },
  "keywords": [
    "pwa",
    "progressive web app",
    "news",
    "dashboard",
    "rss",
    "social listening",
    "offline",
    "service worker"
  ],
  "author": "rmdtkmp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rmdtkmp/news-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/rmdtkmp/news-monitor/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/rmdtkmp"
    }
  ],
  "engines": {
    "node": "20.0.0",
    "npm": "10.0.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.12.0",
    "axios": "^1.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.19.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.10.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0"
  }
}
